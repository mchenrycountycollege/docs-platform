# Cascade REST API — used by packages/cascade-client's live smoke test.
# Do not commit a real .env; this file is just the shape.
CASCADE_BASE_URL=https://your-instance.cascadecms.com
CASCADE_SITE_NAME=docs
CASCADE_API_KEY=
# Internal Cascade ids (not names/paths -- the REST API identifies Content
# Type by id) for the Documentation Page and Nav Output Content Types.
# See _cms/specs/docs-platform/implementation-checklist.md.
CASCADE_DOC_CONTENT_TYPE_ID=
CASCADE_NAV_CONTENT_TYPE_ID=
