    function applyFixed() {
      var parentRect = nav.parentNode.getBoundingClientRect();
      nav.classList.add('is-fixed');
      nav.style.left  = parentRect.left + 'px';
      nav.style.width = parentRect.width + 'px';
      sentinel.style.height = nav.offsetHeight + 'px';
    }

    function clearFixed() {
      nav.classList.remove('is-fixed');
      nav.style.left  = '';
      nav.style.width = '';
      sentinel.style.height = '0';
