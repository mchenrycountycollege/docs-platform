#set($banner = $currentPage.getStructuredDataNode('banner'))

#if($banner.getChild('display').textValue == 'Show')
    #set($slides = $banner.getChildren('slide'))
    <div class="main-slider">
        <div class="orbit" role="region" aria-label="Banner Images" data-orbit="">
        <ul class="orbit-container">
            <button class="orbit-previous"><span class="show-for-sr">Previous Slide</span>&#9664;&#xFE0E;</button>
            <button class="orbit-next"><span class="show-for-sr">Next Slide</span>&#9654;&#xFE0E;</button>
            #foreach($slide in $slides)
                #set($image   = $slide.getChild('image').asset.link) ## required
                #set($caption = $slide.getChild('caption'))          ## optional
                #set($link    = $slide.getChild('link'))             ## optional
                <li class="is-active orbit-slide" style="background:url('[system-asset]${image}[/system-asset]')">
                    #if(!$_PropertyTool.isEmpty($caption.textValue))
                        <figcaption class="orbit-caption ">
                            #if($link.asset)
                                <a href="${link.asset.link}">$_EscapeTool.xml($caption.textValue)</a>    
                            #else 
                                $_EscapeTool.xml($caption.textValue)
                            #end 
                        </figcaption>
                    #end 
                </li>
            #end
        </ul>
        <nav class="orbit-bullets">
             #foreach($s in $slides)
                #if($foreach.first)
                    <button class="is-active" data-slide="${foreach.index}">
                        <span class="show-for-sr">Slide number ${foreach.count} details.</span><span class="show-for-sr">Current Slide</span>
                    </button>
                #else 
                    <button data-slide="${foreach.index}"><span class="show-for-sr">Slide number ${foreach.count} details.</span></button>
                #end
            #end
        </nav>
        </div>
    </div>
#end