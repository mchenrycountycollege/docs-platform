#macro(outputDualAccordions $accordions)
    <div class="row dual-accordions">
        <div class="large-6 columns">
            <div class="accordion" data-accordion="" data-allow-all-closed="true">
                #foreach( $accordion in $accordions.getChild("left").getChildren("accordion"))
                    #set ( $label = $_EscapeTool.xml($accordion.getChild("label").textValue))
                    #set ( $content = $accordion.getChild("content").textValue)
                    #set ( $anchor = "")
                    #set ( $anchor = $_EscapeTool.xml($accordion.getChild("anchor").textValue))
                    <div class="accordion-item " data-accordion-item="" #if(!$_PropertyTool.isEmpty($anchor))id="${anchor}"#end>
                		<a class="accordion-title" href="#">$label</a>
                		<div class="accordion-content" data-tab-content="">
                			$content
                		</div>
                	</div>
                #end
            </div>
        </div>
        <div class="large-6 columns">
            <div class="accordion" data-accordion="" data-allow-all-closed="true">
                #foreach( $accordion in $accordions.getChild("right").getChildren("accordion"))
                    #set ( $label = $_EscapeTool.xml($accordion.getChild("label").textValue))
                    #set ( $content = $accordion.getChild("content").textValue)
                    #set ( $anchor = "")
                    #set ( $anchor = $_EscapeTool.xml($accordion.getChild("anchor").textValue))
                    <div class="accordion-item " data-accordion-item="" #if(!$_PropertyTool.isEmpty($anchor))id="${anchor}"#end>
                		<a class="accordion-title" href="#">$label</a>
                		<div class="accordion-content" data-tab-content="">
                			$content
                		</div>
                	</div>
                #end
            </div>
        </div>
    </div>
#end   