#macro(outputPhotoGallery $row)
    #set ( $gallery = $row.getChildren("image") )
    #set( $caption = $row.getChild("caption").textValues )
    <div class="gallery">
        <div class="row">
            #foreach( $photo in $gallery)
                #set( $image = "" )
        	    #set( $alt = "" )
                #set( $image = $photo.getChild("image").asset.link )
                #set( $alt = $_EscapeTool.xml($photo.getChild("alt").textValue) )
                #if (!$_PropertyTool.isEmpty($image))
            	    <div class="small-3 medium-3 large-3 columns"><img alt="$!{alt}" class="hover-shadow cursor" onclick="openModal('modal-${foreach.parent.count}');currentSlide(${foreach.count}, 'modal-${foreach.parent.count}')" src="${image}" style="width: 100%;" /></div>
            	#end
        	#end
        </div>
        <div class="modal" id="modal-${foreach.count}">
        	<span class="close cursor" onclick="closeModal('modal-${foreach.count}')">&#215;</span>
        	<div class="modal-content">
        	    #foreach( $photo in $gallery)
        	        #set( $image = "" )
        	        #set( $alt = "" )
                    #set( $image = $photo.getChild("image").asset.link )
                    #set( $alt = $_EscapeTool.xml($photo.getChild("alt").textValue) )
                    #if (!$_PropertyTool.isEmpty($image))
                        <div class="mySlides">
                			<div class="numbertext">${foreach.count} / ${gallery.size()}</div>
                			<img src="${image}" alt="$!{alt}" style="width: 100%;" />
                		</div>
            		#end
            	#end
        		<a class="prev" onclick="plusSlides(-1, 'modal-${foreach.count}')">&#10094;</a> <a class="next" onclick="plusSlides(1, 'modal-${foreach.count}')">&#10095;</a>
        		<div class="caption-container">
        			<p #if($caption.contains("yes"))id="caption"#end>&#160;</p>
        		</div>
        		#foreach( $photo in $gallery)
        		   	#set( $image = "" )
        	        #set( $alt = "" )
                    #set( $image = $photo.getChild("image").asset.link )
                    #set( $alt = $_EscapeTool.xml($photo.getChild("alt").textValue) )
                    #if (!$_PropertyTool.isEmpty($image))
                        <div class="small-3 medium-3 large-3 columns"><img alt="$!{alt}" class="demo cursor" onclick="currentSlide(${foreach.count}, 'modal-${foreach.parent.count}')" src="${image}" style="width: 100%;" /></div>
                    #end
            	#end
        	</div>
        </div>
    </div>
#end