                                    #set($bgColorVal = "")
                                    #set($bgColorNode = $logo.getChild("bg-color"))
                                    #if($bgColorNode && $bgColorNode.textValue)
                                        #set($bgColorVal = $bgColorNode.textValue)
                                    #end
