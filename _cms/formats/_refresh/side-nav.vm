#macro(outputCrumbs $asset)
    #if($asset.name && $asset.path != '/')
        #set($crumb = false)
        #outputCrumbs($asset.parentFolder)
        #if($asset.identifier.type == 'folder')
            #set($crumb = $_.locatePage("${asset.path}/index"))
            #if($crumb && $crumb.identifier.id != $currentPage.identifier.id)
                <span>&#62;</span>
                <a href="${crumb.link}" class="breadcrumbs__link">$_EscapeTool.xml($crumb.label)</a>
            #end
        #end
    #else
        #break    
    #end
#end
#####################################
#macro(outputBreadcrumbs)
    <div class="sidenav-bg__breadcrum"> 
        <a href="site://McHenry/index">Home</a> 
        #outputCrumbs($currentPage)
        <span>&#62;</span> $_EscapeTool.xml($currentPage.label)
     </div>
#end 
#####################################
#macro(outputNav)
    <ul class="sidenav-links">
        ## #if (!$currentPage.metadata.getDynamicField("navExclude").values.contains("yes"))
        ##     <li>${_EscapeTool.xml($currentPage.label)}</li>
        ## #end
        #foreach($asset in $currentPage.parentFolder.children)
            #if($asset.assetType == 'folder')
                #set($index = false)
                #set($index = $_.locatePage("${asset.path}/index"))
                #if($index)
                    #set($asset = $index)
                #end 
            #end 
            #if($assetTypes.contains($asset.assetType) || ($asset.assetType == "page" && !$asset.metadata.getDynamicField("navExclude").values.contains("yes") && $asset.identifier.id != $currentPage.identifier.id))
                #if ($asset.assetType == "reference")
                    #set ($asset = $asset.referencedAsset)
                #end
                ## Check if link is to a PDF file and add class to suppress icon
                #if($asset.link.toLowerCase().endsWith(".pdf"))
                    <li><a href="${asset.link}" class="no-pdf-icon">${asset.label}</a></li>
                #else
                    <li><a href="${asset.link}">${asset.label}</a></li>
                #end
           #end 
        #end 
    </ul>
#end 