<!--
  Block Seed XML: golf-sponsors-block
  ====================================
  Use this as sample/reference content when creating the XHTML/Data Definition Block
  in the Cascade CMS UI. Paste this into "Content (XML)" when creating the block,
  or use it as a reference to manually populate the block form fields.

  IMPORTANT: image <path> values below are placeholders.
  Replace each with the actual CMS asset path after uploading sponsor logos to
  /_files/golf-invitational/sponsors/ (or your site's file folder for this event).

  To use in Cascade:
    1. Create an XHTML/Data Definition Block named "golf-invitational-sponsors"
    2. Assign the Data Definition "golf-invitational-sponsors" created from data-definition.xml
    3. Populate fields using this XML as a reference, OR paste raw XML into the source view

  Block DD group structure:
    tier (multiple)
      tier-name         — required, text
      tier-subtitle     — optional, text
      logo (multiple)
        image           — required, file asset
        alt             — required, text (sponsor's full name)
        link            — optional, text (full URL)
-->
<system-data-structure>

  <!-- ═══════════════════════════════════════════
       TIER 1: Presenting — highest prestige level
  ══════════════════════════════════════════════ -->
