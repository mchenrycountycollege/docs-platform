## Documentation Page render Format.
## Assigned to the default region of pages using the Documentation Page
## Content Type -- lands inside the docs-platform-page Template's
## <system-region name="DEFAULT"/>, alongside a static topbar the Template
## itself provides. Emits exactly the three grid children the Template's
## CSS expects: #docs-sidebar, #docs-content, #docs-rail. The client
## runtime (packages/runtime, bundled into the Template's inline <script>)
## fetches _system/nav/<book>.json + _system/search-index.json and
## hydrates the sidebar tree, breadcrumb, and Cmd+K search. Deriving the
## book slug from the path and building the breadcrumb is left to that JS
## (trivial there, brittle to guess correctly here in Velocity), so this
## Format only needs to emit the raw page path.

#set($titleNode = $currentPage.getStructuredDataNode("title"))
#set($tagNodes = $currentPage.getStructuredDataNodes("tags"))
#set($docPath = $currentPage.path)
## $currentPage.getStructuredDataNode() returns Cascade's PageAPIAdapter
## wrapper, not a JDOM Element -- fine for .textValue, but SerializerTool
## needs a real Element (confirmed live: passing the wrapper in doesn't
## error, it just silently fails to resolve and prints the literal source).
## $contentRoot is documented as a genuine JDOM Element, so fetch body via
## XPath against that instead, matching the docs' own WYSIWYG example.
#set($bodyNode = $_XPathTool.selectSingleNode($contentRoot, "//body"))

## Provenance metadata (docId/origin/sourceRepoPath/editorName/authorEmail)
## lives in the Metadata Set, same wrapper family the Query API results in
## _shared.vm's extractDocFields already read via .metadata.getDynamicField.
#set($sourceRepoPathNode = $currentPage.metadata.getDynamicField("sourceRepoPath"))
#set($sourceRepoPath = $sourceRepoPathNode.value)
## Attribution: both write paths stamp authorEmail (git publish: commit
## author or frontmatter override; web editor: session username-or-email).
## editorName is vestigial -- only the Phase-0 smoke script ever set it --
## kept as a fallback for those early assets. When the field is unset,
## getDynamicField returns null and .value leaves the variable undefined,
## which the #if guard below treats the same as empty (matching the
## $sourceRepoPath pattern above).
#set($authorEmailNode = $currentPage.metadata.getDynamicField("authorEmail"))
#set($lastEditedBy = $authorEmailNode.value)
#if(!$lastEditedBy || $lastEditedBy.length() == 0)
    #set($editorNameNode = $currentPage.metadata.getDynamicField("editorName"))
    #set($lastEditedBy = $editorNameNode.value)
#end

<nav aria-label="Documentation navigation" class="sidebar" id="docs-sidebar">
    <!-- hydrated client-side from _system/nav/<book>.json -->
</nav>
<main class="content-col" id="docs-content">
    <article class="content">
        <header>
            <h1 id="startcontent">$_EscapeTool.xml($titleNode.textValue)</h1>
            #if($tagNodes.size() > 0)
            <ul class="doc-tags">
                #foreach($tagNode in $tagNodes)
                <li><a href="/docs/tags/$_EscapeTool.url($tagNode.textValue.toLowerCase())">$_EscapeTool.xml($tagNode.textValue)</a></li>
                #end
            </ul>
            #end
        </header>
        <div class="docs-body">
            $_SerializerTool.serialize($bodyNode, true)
        </div>
    </article>
</main>
<aside aria-label="Page information" class="rail" id="docs-rail">
    #if($sourceRepoPath && $sourceRepoPath.length() > 0)
    <div class="rail-box">
        <p class="rail-label">Source file</p>
        <span class="source-path">$_EscapeTool.xml($sourceRepoPath)</span>
    </div>
    #end
    #if($lastEditedBy && $lastEditedBy.length() > 0)
    <div class="rail-box">
        <p class="rail-label">Last edited by</p>
        <span class="rail-author">$_EscapeTool.xml($lastEditedBy)</span>
    </div>
    #end
    <div class="rail-box" id="page-toc-box" style="display: none;">
        <p class="rail-label">On this page</p>
        <ul class="toc-list" id="page-toc"></ul>
    </div>
</aside>

<script id="docs-runtime-config" type="application/json">
//<![CDATA[
#set($configMap = {"path": $docPath, "title": $titleNode.textValue, "searchUrl": "/docs/_system/search-index.json"})
$_SerializerTool.toJson($configMap)
//]]>
</script>
