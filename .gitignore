# actions/publish/dist is a checked-in bundle, not a build cache -- GitHub
# Actions can't run `pnpm install`/build for a referenced action, so the
# bundled dist/index.js this repo ships must be committed.
!actions/publish/dist/
!actions/publish/dist/**
